<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hardtekk Bunker | Audio Manager</title>
    <style>
        :root {
            --bg-dark: #030303;
            --bg-card: #0a0a0a;
            --bg-input: #0f0f0f;
            --tekk-yellow: #ffcc00;
            --tekk-purple: #8a00b0;
            --border-color: #1a1a1a;
            --text-main: #ffffff;
            --text-muted: #666666;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
        }

        /* --- LOGIN POP-UP (MODAL) --- */
        #login-modal {
            display: none;
            position: fixed;
            z-index: 99999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(10px);
            justify-content: center;
            align-items: center;
        }
        .login-box {
            background-color: var(--bg-card);
            padding: 40px;
            border-radius: 12px;
            border: 1px solid var(--tekk-yellow);
            box-shadow: 0 0 30px rgba(255, 204, 0, 0.2);
            width: 100%;
            max-width: 320px;
            text-align: center;
            position: relative;
        }
        .close-btn {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 24px;
            color: var(--text-muted);
            cursor: pointer;
        }
        .close-btn:hover { color: white; }
        .login-box h1 {
            color: var(--tekk-yellow);
            font-size: 22px;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
        }

        /* --- HAUPTLAYOUT --- */
        #app-screen {
            width: 100%;
            max-width: 1400px;
            padding: 20px;
            box-sizing: border-box;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 15px;
            margin-bottom: 30px;
            position: relative;
        }
        .logo-area {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-box-text {
            background: linear-gradient(45deg, #ff9900, var(--tekk-yellow));
            color: black;
            font-weight: 900;
            padding: 5px 10px;
            border-radius: 4px;
            text-transform: uppercase;
            font-size: 14px;
            letter-spacing: 1px;
        }
        .logo-title {
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 18px;
        }
        .nav-tabs {
            display: flex;
            gap: 5px;
        }
        .nav-tabs button {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            padding: 10px 14px;
            transition: color 0.2s;
            border-bottom: 2px solid transparent;
        }
        .nav-tabs button:hover, .nav-tabs button.active {
            color: var(--tekk-yellow);
            border-bottom: 2px solid var(--tekk-yellow);
        }

        #display-user {
            position: relative;
            z-index: 9999; 
            cursor: pointer;
            pointer-events: auto;
        }

        .user-btn-badge {
            background-color: #111;
            border: 1px solid #382d00;
            color: var(--tekk-yellow);
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 12px;
            cursor: pointer;
            font-weight: bold;
            display: inline-block;
        }
        .user-btn-badge:hover {
            background-color: #1a1a00;
            border-color: var(--tekk-yellow);
        }

        .page { display: none; }
        .page.active { display: block; }

        .page-title {
            font-size: 32px;
            font-weight: 900;
            text-transform: uppercase;
            color: var(--tekk-yellow);
            letter-spacing: 1px;
            margin: 0 0 5px 0;
            text-shadow: 0 0 15px rgba(255, 204, 0, 0.2);
        }
        .page-subtitle {
            color: var(--text-muted);
            font-size: 13px;
            margin: 0 0 30px 0;
        }

        .top-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }
        @media (max-width: 900px) {
            .top-grid { grid-template-columns: 1fr; }
        }

        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 25px;
            box-sizing: border-box;
        }
        .card-header {
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
            color: #aaa;
        }

        .input-field {
            width: 100%;
            padding: 14px;
            background-color: var(--bg-input);
            border: 1px solid var(--border-color);
            color: white;
            border-radius: 6px;
            box-sizing: border-box;
            font-size: 14px;
            margin-bottom: 15px;
        }
        .input-field:focus { border-color: #333; outline: none; }
        .input-field::placeholder { color: #333; }

        .input-row { display: flex; gap: 15px; }

        .btn-yellow {
            width: 100%;
            padding: 14px;
            background: linear-gradient(180deg, #ffe600 0%, var(--tekk-yellow) 100%);
            color: black;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 800;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(255, 204, 0, 0.2);
        }

        .api-box {
            display: flex;
            background-color: var(--bg-input);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            padding: 12px 15px;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }
        .api-url-text { color: var(--tekk-yellow); font-family: monospace; font-size: 14px; font-weight: bold; }
        
        .btn-outline {
            background: none;
            border: 1px solid #222;
            color: white;
            padding: 8px 14px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            cursor: pointer;
        }

        .table-section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-top: 1px solid var(--border-color);
            padding-top: 25px;
        }
        .songs-count-title {
            font-size: 16px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .counter-badge {
            background-color: #241c00;
            color: var(--tekk-yellow);
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 10px;
            border: 1px solid #473b00;
        }

        .filter-area { display: flex; gap: 10px; }
        .search-input {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            color: white;
            padding: 10px 15px;
            border-radius: 6px;
            font-size: 13px;
            width: 200px;
        }
        .select-filter {
            background-color: var(--bg-card);
            color: white;
            border: 1px solid var(--border-color);
            padding: 10px 15px;
            border-radius: 6px;
            font-size: 13px;
        }

        table { width: 100%; border-collapse: collapse; }
        th {
            color: var(--text-muted);
            text-transform: uppercase;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            padding: 12px 10px;
            border-bottom: 1px solid var(--border-color);
            text-align: left;
        }
        td { padding: 16px 10px; font-size: 14px; border-bottom: 1px solid #0a0a0a; color: #aaa; }
        tr:hover td { background-color: #050505; color: white; }
        
        .id-badge { font-family: monospace; color: #777; }
        .category-badge {
            background-color: #141414;
            color: #888;
            font-size: 11px;
            padding: 4px 10px;
            border-radius: 12px;
            border: 1px solid #222;
        }
        #login-error { color: #ff3333; margin-top: 15px; font-weight: bold; font-size: 13px; min-height: 18px; }
    </style>
</head>
<body>

    <div id="login-modal">
        <div class="login-box">
            <span class="close-btn" onclick="closeLoginModal()">&times;</span>
            <h1>Team Login</h1>
            <input type="text" id="login-username" class="input-field" placeholder="Benutzername">
            <input type="password" id="login-password" class="input-field" placeholder="Passwort">
            <button class="btn-yellow" onclick="versucheLogin()">Einloggen</button>
            <div id="login-error"></div>
        </div>
    </div>

    <div id="app-screen">
        <nav>
            <div class="logo-area">
                <div class="logo-box-text">Bunker</div>
                <div class="logo-title">Hardtekk Bunker</div>
            </div>
            <div class="nav-tabs">
                <button id="tab-home" class="active" onclick="switchTab('home')">🎧 DJ Console</button>
                <button id="tab-upload" onclick="switchTab('upload')">🎵 Audio Manager</button>
                <button id="tab-categories" onclick="switchTab('categories')">🗂️ Kategorien</button>
                <button id="tab-team" onclick="switchTab('team')">👤 Benutzer</button>
                <button id="tab-api" onclick="switchTab('api')">🌐 Roblox API</button>
                <button id="tab-playlist" onclick="switchTab('playlist')">📜 Playlists</button>
            </div>
            <div id="display-user">
                <button class="user-btn-badge" onclick="openLoginModal()">🔑 Login</button>
            </div>
        </nav>

        <div id="page-home" class="page active">
            <h1 class="page-title">Roblox Audio Manager</h1>
            <p class="page-subtitle">Verwalte deine Song-IDs und nutze die API in Roblox.</p>

            <div class="top-grid">
                <div class="card">
                    <div class="card-header">🟡 Roblox API URL</div>
                    <div class="api-box">
                        <span class="api-url-text">/api/roblox/songs</span>
                        <button class="btn-outline">📋 Kopieren</button>
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <button class="btn-outline" style="flex:1;">👁️ JSON Vorschau</button>
                        <button class="btn-outline" style="flex:1;">⚡ API Testen</button>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">➕ Song hinzufügen</div>
                    <div id="upload-form-container">
                        <p id="guest-info-text" style="color: var(--text-muted); font-size: 13px; margin: 0 0 15px 0;">Logge dich oben ein, um neue Musik in die Datenbank einzuspeisen.</p>
                        <div id="secret-upload-fields" style="display: none;">
                            <input type="text" id="up-artist" class="input-field" placeholder="Künstlername (z.B. Nogge)">
                            <div class="input-row">
                                <input type="text" id="up-title" class="input-field" placeholder="Songtitel">
                                <input type="text" id="up-id" class="input-field" placeholder="Roblox Audio ID">
                            </div>
                            <button class="btn-yellow" onclick="uploadTrack()">➕ Song hinzufügen</button>
                            <div id="upload-status" style="margin-top: 10px; font-size: 13px; font-weight: bold;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-section-header">
                <div class="songs-count-title">🎵 Songs <span class="counter-badge" id="songs-counter">0</span></div>
                <div class="filter-area">
                    <input type="text" class="search-input" placeholder="Name, ID, Kategorie...">
                    <select class="select-filter"><option value="alle">Alle</option></select>
                </div>
            </div>

            <div class="card" style="padding: 10px 20px;">
                <table>
                    <thead>
                        <tr>
                            <th style="width: 5%;">#</th>
                            <th style="width: 50%;">Name</th>
                            <th style="width: 25%;">Song ID</th>
                            <th style="width: 20%;">Kategorie</th>
                        </tr>
                    </thead>
                    <tbody id="playlist-body"></tbody>
                </table>
            </div>
        </div>

        <div id="page-upload" class="page card"><h2>🎵 Audio Manager Settings</h2></div>
        <div id="page-categories" class="page card"><h2>🗂️ Kategorien</h2></div>
        <div id="page-team" class="page card">
            <div class="card-header">👑 Benutzer & Ränge Verwaltung</div>
            <div id="admin-only-content" style="display: none;">
                <div style="display: flex; gap: 10px; margin-bottom: 20px;">
                    <input type="text" id="new-user-name" class="input-field" placeholder="Name" style="margin:0;">
                    <input type="text" id="new-user-pass" class="input-field" placeholder="Passwort" style="margin:0;">
                    <select id="new-user-role" class="input-field" style="margin:0; background-color: var(--bg-input); color:white;">
                        <option value="Admin">Admin</option>
                        <option value="Moderator">Moderator</option>
                        <option value="IDs-Manager">IDs-Manager</option>
                    </select>
                    <button class="btn-yellow" style="width: auto; padding: 0 20px;" onclick="createNewUser()">Erstellen</button>
                </div>
                <table style="width:100%;">
                    <thead><tr><th>Name</th><th>Rang</th><th>Aktion</th></tr></thead>
                    <tbody id="team-body"></tbody>
                </table>
            </div>
            <p id="admin-lock-text" style="color: var(--text-muted);">Nur für Admins sichtbar. Bitte logge dich ein.</p>
        </div>
        <div id="page-api" class="page card"><h2>🌐 Roblox API</h2></div>
        <div id="page-playlist" class="page card"><h2>📜 Playlists</h2></div>
    </div>

    <script>
        const SUPABASE_URL = "https://xyzbjnxrhzdcxuuwfvuq.supabase.co";
        const SUPABASE_KEY = "sb_publishable_Kp5QnlVPRhgGm221Iz1b6Q_wHcdXmKH";
        let currentUser = null;

        window.onload = () => { 
            ladePlaylist(); 
        };

        function openLoginModal() {
            document.getElementById('login-modal').style.display = 'flex';
            document.getElementById('login-error').innerText = '';
        }
        function closeLoginModal() {
            document.getElementById('login-modal').style.display = 'none';
        }

        function formatRole(role) {
            if (role === 'Owner') return '👑 Owner';
            if (role === 'Admin') return '⚡ Admin';
            if (role === 'Moderator') return '🛡️ Moderator';
            if (role === 'IDs-Manager') return '🎵 IDs-Manager';
            return role;
        }

        async function versucheLogin() {
            const userIn = document.getElementById('login-username').value.trim();
            const passIn = document.getElementById('login-password').value.trim();
            const errorDiv = document.getElementById('login-error');

            if (!userIn || !passIn) {
                errorDiv.style.color = "#ff3333";
                errorDiv.innerText = "Bitte Daten eingeben!";
                return;
            }
            
            errorDiv.style.color = "#ffffff";
            errorDiv.innerText = "Verbindung zum Bunker wird aufgebaut...";

            try {
                const res = await fetch(`${SUPABASE_URL}/rest/v1/team_users?username=eq.${userIn}&select=*`, {
                    headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` }
                });
                const data = await res.json();

                if (data && data.message) {
                    errorDiv.style.color = "#ff3333";
                    errorDiv.innerText = `Datenbank meldet Fehler: ${data.message}`;
                    return;
                }

                if (!Array.isArray(data) || data.length === 0 || data[0].password !== passIn) {
                    errorDiv.style.color = "#ff3333";
                    errorDiv.innerText = "Falscher Benutzername oder Passwort!";
                } else {
                    currentUser = data[0];
                    closeLoginModal();
                    
                    document.getElementById('display-user').innerHTML = `
                        <span style="color: var(--tekk-yellow); font-size:13px; font-weight:bold; margin-right:12px;">
                            ${formatRole(currentUser.role)} | ${currentUser.username}
                        </span>
                        <button class="user-btn-badge" style="color: #ff3333; border-color: #441111; background:#111;" onclick="logout()">Logout</button>
                    `;
                    
                    document.getElementById('guest-info-text').style.display = 'none';
                    document.getElementById('secret-upload-fields').style.display = 'block';

                    if (currentUser.role === 'Owner' || currentUser.role === 'Admin') {
                        if(document.getElementById('admin-only-content')) document.getElementById('admin-only-content').style.display = 'block';
                        if(document.getElementById('admin-lock-text')) document.getElementById('admin-lock-text').style.display = 'none';
                        ladeTeam();
                    }
                }
            } catch (err) {
                errorDiv.style.color = "#ff3333";
                errorDiv.innerText = "Verbindungsfehler: " + err.message;
            }
        }

        function logout() {
            currentUser = null;
            document.getElementById('display-user').innerHTML = `
                <button class="user-btn-badge" onclick="openLoginModal()">🔑 Login</button>
            `;
            document.getElementById('guest-info-text').style.display = 'block';
            document.getElementById('secret-upload-fields').style.display = 'none';
            if(document.getElementById('admin-only-content')) document.getElementById('admin-only-content').style.display = 'none';
            if(document.getElementById('admin-lock-text')) document.getElementById('admin-lock-text').style.display = 'block';
            switchTab('home');
        }

        function switchTab(tabId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-tabs button').forEach(b => b.classList.remove('active'));
            document.getElementById('page-' + tabId).classList.add('active');
            document.getElementById('tab-' + tabId).classList.add('active');
            if (tabId === 'home') ladePlaylist();
            if (tabId === 'team' && currentUser) ladeTeam();
        }

        async function ladePlaylist() {
            const tbody = document.getElementById('playlist-body');
            try {
                const res = await fetch(`${SUPABASE_URL}/rest/v1/playlist?order=id.desc`, { 
                    headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` } 
                });
                const data = await res.json();
                tbody.innerHTML = '';
                
                if (Array.isArray(data)) {
                    document.getElementById('songs-counter').innerText = data.length;
                } else {
                    document.getElementById('songs-counter').innerText = "0";
                }

                let index = 1;
                data.forEach(song => {
                    let kat = song.role && song.role.includes('(') ? song.role.split('(')[1].replace(')', '') : 'Tekk';
                    tbody.innerHTML += `
                        <tr>
                            <td>${index++}</td>
                            <td style="font-weight:bold; color:white;">${song.artist} - ${song.title}</td>
                            <td><span class="id-badge">${song.audio_id}</span></td>
                            <td><span class="category-badge">${kat}</span></td>
                        </tr>`;
                });
            } catch (e) { 
                tbody.innerHTML = '<tr><td colspan="4">Fehler beim Laden der Playlist.</td></tr>'; 
            }
        }

        async function uploadTrack() {
            if (!currentUser) return;
            const artist = document.getElementById('up-artist').value;
            const title = document.getElementById('up-title').value;
            const audioId = document.getElementById('up-id').value;
            const statusDiv = document.getElementById('upload-status');
            
            if (!artist || !title || !audioId) { 
                statusDiv.style.color = "#ff3333"; 
                statusDiv.innerText = "Alle Felder ausfüllen!"; 
                return; 
            }

            statusDiv.style.color = "white"; 
            statusDiv.innerText = "Speichere im Bunker...";
            const uploaderInfo = `${currentUser.username} (${currentUser.role})`;

            try {
                const res = await fetch(`${SUPABASE_URL}/rest/v1/playlist`, {
                    method: 'POST',
                    headers: { 
                        'apikey': SUPABASE_KEY, 
                        'Authorization': `Bearer ${SUPABASE_KEY}`, 
                        'Content-Type': 'application/json', 
                        'Prefer': 'return=minimal' 
                    },
                    body: JSON.stringify({ role: uploaderInfo, artist: artist, title: title, audio_id: audioId })
                });
                if (res.ok) {
                    statusDiv.style.color = "#00ff66"; 
                    statusDiv.innerText = "Erfolgreich! Live.";
                    document.getElementById('up-artist').value = ''; 
                    document.getElementById('up-title').value = ''; 
                    document.getElementById('up-id').value = '';
                    ladePlaylist();
                }
            } catch (e) { 
                statusDiv.style.color = "#ff3333"; 
                statusDiv.innerText = "Fehler beim Hochladen."; 
            }
        }

        async function ladeTeam() {
            const tbody = document.getElementById('team-body');
            if(!tbody) return;
            try {
                const res = await fetch(`${SUPABASE_URL}/rest/v1/team_users?order=role.asc`, { 
                    headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` } 
                });
                const data = await res.json();
                tbody.innerHTML = '';
                data.forEach(user => {
                    let actionBtn = user.role !== 'Owner' ? `<button class="btn-outline" style="color:#ff3333;" onclick="deleteUser(${user.id}, '${user.username}')">Löschen</button>` : '';
                    tbody.innerHTML += `<tr><td style="font-weight:bold; color:white;">${user.username}</td><td>${formatRole(user.role)}</td><td>${actionBtn}</td></tr>`;
                });
            } catch (e) {}
        }

        async function createNewUser() {
            const name = document.getElementById('new-user-name').value;
            const pass = document.getElementById('new-user-pass').value;
            const role = document.getElementById('new-user-role').value;
            if (!name || !pass) return;
            try {
                await fetch(`${SUPABASE_URL}/rest/v1/team_users`, {
                    method: 'POST',
                    headers: { 
                        'apikey': SUPABASE_KEY, 
                        'Authorization': `Bearer ${SUPABASE_KEY}`, 
                        'Content-Type': 'application/json', 
                        'Prefer': 'return=minimal' 
                    },
                    body: JSON.stringify({ username: name, password: pass, role: role })
                });
                document.getElementById('new-user-name').value = ''; 
                document.getElementById('new-user-pass').value = ''; 
                ladeTeam();
            } catch (e) {}
        }

        async function deleteUser(id, name) {
            if (!confirm(`Account '${name}' löschen?`)) return;
            try {
                await fetch(`${SUPABASE_URL}/rest/v1/team_users?id=eq.${id}`, { 
                    method: 'DELETE', 
                    headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` } 
                });
                ladeTeam();
            } catch (e) {}
        }
    </script>
</body>
</html>
